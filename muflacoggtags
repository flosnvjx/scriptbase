# Future-Proof Case-Enforcing Wrapper (Public API Only)
class CaseEnforcingVorbisComment:
    """
    Wrapper for Vorbis Comment files that ENFORCES UPPERCASE tag keys.
    Uses ONLY public Mutagen APIs. No internal monkey-patching.
    Preserves your script's uppercase convention while remaining API-compatible.
    """
    def __init__(self, audio_file):
        self._audio = audio_file
    # ------------------------------
    # Core Public API Implementation
    # ------------------------------
    def _enforce_upper_key(self, key):
        """Ensure all keys are UPPERCASE before any operation."""
        if not isinstance(key, str):
            raise KeyError(f"Tag keys must be strings (got {type(key).__name__})")
        return key.strip().upper()
    def __getitem__(self, key):
        """Get a tag by key (key is auto-converted to UPPERCASE)."""
        upper_key = self._enforce_upper_key(key)
        try:
            return self._audio.tags[upper_key]
        except KeyError:
            # Match Mutagen's behavior: raise KeyError only if the key is missing
            raise KeyError(key) from None
    def __setitem__(self, key, value):
        """Set a tag (key is auto-converted to UPPERCASE)."""
        upper_key = self._enforce_upper_key(key)
        self._audio.tags[upper_key] = value
    def __delitem__(self, key):
        """Delete a tag (key is auto-converted to UPPERCASE)."""
        upper_key = self._enforce_upper_key(key)
        del self._audio.tags[upper_key]
    def __contains__(self, key):
        """Check key existence (key is auto-converted to UPPERCASE)."""
        upper_key = self._enforce_upper_key(key)
        return upper_key in self._audio.tags
    def keys(self):
        """Return all tag keys (preserved as UPPERCASE)."""
        return [k.upper() for k in self._audio.tags.keys()]
    def items(self):
        """Return all (key, value) pairs (keys as UPPERCASE)."""
        return [(k.upper(), v) for k, v in self._audio.tags.items()]
    def values(self):
        """Return all tag values."""
        return self._audio.tags.values()
    def get(self, key, default=None):
        """Get a tag with fallback (key auto-converted to UPPERCASE)."""
        upper_key = self._enforce_upper_key(key)
        return self._audio.tags.get(upper_key, default)
    def clear(self):
        """Clear all tags."""
        self._audio.tags.clear()
    # ------------------------------
    # Forward Compatibility (Public FLAC Picture API)
    # ------------------------------
    def __getattr__(self, name):
        """Forward all other attribute access to the underlying audio file."""
        return getattr(self._audio, name)

