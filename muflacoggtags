# Modified Open Functions (Add stdin buffer support + CASE-ENFORCEMENT)
# -----------------------------------------------------------------------------
def open_audio_file(file_path: str, stdin_buffer: BytesIO = None):
    """
    Open an audio file with CASE-ENFORCEMENT (UPPERCASE keys).
    Supports stdin buffer (BytesIO) for - positional parameter.
    Returns a wrapped object that behaves like the original, but enforces uppercase.
    """
    try:
        if stdin_buffer is not None:
            # Read from in-memory buffer (stdin data) - detect format automatically
            stdin_buffer.seek(0)
            # Try FLAC first, then OggVorbis (oga/ogg), then OggOpus
            try:
                audio = OriginalFLAC(stdin_buffer)
            except MutagenError:
                stdin_buffer.seek(0)
                try:
                    audio = OriginalOggVorbis(stdin_buffer)
                except MutagenError:
                    stdin_buffer.seek(0)
                    audio = OriginalOggOpus(stdin_buffer)
        else:
            # Original file path handling
            ext = file_path.lower().split('.')[-1]
            if ext == 'flac':
                audio = OriginalFLAC(file_path)
            elif ext in ('ogg', 'oga'):
                audio = OriginalOggVorbis(file_path)
            elif ext == 'opus':
                audio = OriginalOggOpus(file_path)
            else:
                raise MutagenError(f"unsupported format: .{ext} (only flac/ogg/oga/opus)")
        # Wrap the audio file to enforce UPPERCASE keys (NO HACKING!)
        return CaseEnforcingVorbisComment(audio)
    except MutagenError as e:
        raise e
    except Exception as e:
        raise MutagenError(f"file access failed: {str(e)}")

