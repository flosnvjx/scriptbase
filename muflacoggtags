# -----------------------------------------------------------------------------
# Helper: Resolve symlinks + validate regular file (abort on failure)
# -----------------------------------------------------------------------------
def resolve_and_check_regular_file(file_path: str) -> str:
    # Skip validation for stdin marker (-)
    if file_path == '-':
        return '-'
    try:
        resolved_path = os.path.realpath(file_path)
    except OSError as e:
        print(f"error: failed to resolve file (symlink loop/perm denied): {file_path} → {e}", file=sys.stderr)
        sys.exit(1)
    
    if not exists(resolved_path):
        print(f"error: file not found (after symlink resolve): {file_path} → {resolved_path}", file=sys.stderr)
        sys.exit(1)
    
    if not os.path.isfile(resolved_path):
        file_type = "directory" if os.path.isdir(resolved_path) else "non-regular (device/pipe/socket)"
        print(f"error: not a regular file (after symlink resolve): {file_path} → {resolved_path} ({file_type})", file=sys.stderr)
        sys.exit(1)
    
    return resolved_path

# -----------------------------------------------------------------------------
# Helper: Get devmaj+devmin+inodenum triplet (unique physical file ID)
# -----------------------------------------------------------------------------
def get_file_ident_triplet(file_path: str) -> Tuple[int, int, int]:
    # Skip triplet for stdin marker (-)
    if file_path == '-':
        return (-1, -1, -1)
    try:
        stat_info = os.stat(file_path)
        devmaj = os.major(stat_info.st_dev)
        devmin = os.minor(stat_info.st_dev)
        inodenum = stat_info.st_ino
        return (devmaj, devmin, inodenum)
    except OSError as e:
        print(f"error: failed to get file metadata: {file_path} → {e}", file=sys.stderr)
        sys.exit(1)

# -----------------------------------------------------------------------------
# Pure Python Sparse File Wrapper (Linux standard, no libc hardcode)
# -----------------------------------------------------------------------------
FALLOC_FL_PUNCH_HOLE = 0x00000020
FALLOC_FL_KEEP_SIZE = 0x00000001
FALLOC_MODE = FALLOC_FL_PUNCH_HOLE | FALLOC_FL_KEEP_SIZE

class SparseTagFile:
    def __init__(self, path: str):
        self.fd = os.open(path, os.O_RDWR)
        self._fallocate_supported = self._check_fallocate_support()

    def _check_fallocate_support(self) -> bool:
        try:
            original_offset = os.lseek(self.fd, 0, os.SEEK_CUR)
            os.posix_fallocate(self.fd, 0, 0)
            os.lseek(self.fd, original_offset, os.SEEK_SET)
            return True
        except (AttributeError, OSError):
            return False

    def write(self, data: bytes) -> int:
        if not data:
            return 0
        if self._fallocate_supported and all(b == 0 for b in data):
            return self._punch_hole(len(data))
        return os.write(self.fd, data)

    def _punch_hole(self, size: int) -> int:
        try:
            current_offset = os.lseek(self.fd, 0, os.SEEK_CUR)
            falloc_pack = struct.pack('iqq', FALLOC_MODE, current_offset, size)
            fcntl.fcntl(self.fd, fcntl.FALLOCATE, falloc_pack)
            os.lseek(self.fd, current_offset + size, os.SEEK_SET)
            return size
        except Exception:
            return os.write(self.fd, b'\x00' * size)

    def seek(self, offset: int, whence: int = 0) -> int:
        return os.lseek(self.fd, offset, whence)

    def tell(self) -> int:
        return os.lseek(self.fd, 0, os.SEEK_CUR)

    def close(self):
        if hasattr(self, 'fd') and self.fd != -1:
            os.close(self.fd)
            self.fd = -1

    def __enter__(self):
        return self

    def __exit__(self, *args):
        self.close()

