def load_tags(source: str) -> List[Tuple[str, str]]:
    items = []
    lines = []
    try:
        if source == '-':
            lines = [line.rstrip('\n').strip() for line in sys.stdin]
        else:
            with open(source, 'r', encoding='utf-8') as f:
                lines = [line.rstrip('\n').strip() for line in f]
    except Exception as e:
        print(f"error: read failed (source: {source}): {e}", file=sys.stderr)
        sys.exit(1)
    for line in lines:
        if not line or '=' not in line:
            print(f"error: invalid tag entry (missing '='): '{line}'", file=sys.stderr)
            sys.exit(1)
        k, v = line.split('=', 1)
        k = k.strip().upper()
        if not k:
            print(f"error: empty tag key: '{line}'", file=sys.stderr)
            sys.exit(1)
        for c in k:
            if ord(c) < 0x20 or ord(c) > 0x7D or c == '=' or c == '~':
                print(f"error: invalid char in key '{k}' (only printable ASCII, no =/~)", file=sys.stderr)
                sys.exit(1)
        items.append((k, v.strip()))
    return items

def tags_are_equal(audio1, audio2) -> bool:
    if set(audio1.keys()) != set(audio2.keys()):
        return False
    for key in audio1:
        if list(audio1[key]) != list(audio2[key]):
            return False
    if isinstance(audio1, FLAC) and isinstance(audio2, FLAC):
        if len(audio1.pictures) != len(audio2.pictures):
            return False
        for p1, p2 in zip(audio1.pictures, audio2.pictures):
            if p1.data != p2.data or p1.type != p2.type or p1.mime != p2.mime or p1.desc != p2.desc:
                return False
    return True

def parse_kv(kv: str) -> Tuple[str, str]:
    if '=' not in kv:
        print(f"error: invalid tag entry (missing '='): '{kv}'", file=sys.stderr)
        sys.exit(1)
    k, v = kv.split('=', 1)
    k = k.strip().upper()
    if not k:
        print(f"error: empty tag key: '{kv}'", file=sys.stderr)
        sys.exit(1)
    for c in k:
        if ord(c) < 0x20 or ord(c) > 0x7D or c == '=' or c == '~':
            print(f"error: invalid char in key '{k}' (only printable ASCII, no =/~)", file=sys.stderr)
            sys.exit(1)
    return (k, v.strip())

def print_flac_pictures(flac: FLAC, file_path: str):
    if not isinstance(flac, FLAC):
        print(f"error: --flac-list-picture only supports FLAC (file: {file_path})", file=sys.stderr)
        sys.exit(1)
    if len(flac.pictures) == 0:
        print(f"no picture blocks found for {file_path}", file=sys.stdout)
        return
    pic_type_map = {
        0: "Other",
        1: "32x32 pixels 'file icon' (PNG only)",
        2: "Other file icon",
        3: "Front cover",
        4: "Back cover",
        5: "Leaflet page",
        6: "Media (e.g. label side of CD)",
        7: "Lead artist/lead performer/soloist",
        8: "Artist/performer",
        9: "Conductor",
        10: "Band/Orchestra",
        11: "Composer",
        12: "Lyricist/text writer",
        13: "Recording Location",
        14: "During recording",
        15: "During performance",
        16: "Movie/video screen capture",
        17: "A bright coloured fish",
        18: "Illustration",
        19: "Band/artist logotype",
        20: "Publisher/Studio logotype"
    }
    for idx, pic in enumerate(flac.pictures):
        print(f"\npicture block {idx+1} for {file_path}:")
        pic_type = pic.type if hasattr(pic, 'type') else 0
        pic_type_desc = pic_type_map.get(pic_type, f"Unknown ({pic_type})")
        print(f"  type: {pic_type} ({pic_type_desc})")
        mime = pic.mime.decode('utf-8') if isinstance(pic.mime, bytes) else pic.mime
        print(f"  MIME type: {mime}")
        desc = pic.desc.decode('utf-8') if (isinstance(pic.desc, bytes) and pic.desc) else ""
        print(f"  description: {desc}")
        width = pic.width if hasattr(pic, 'width') else 0
        height = pic.height if hasattr(pic, 'height') else 0
        depth = pic.depth if hasattr(pic, 'depth') else 0
        print(f"  width: {width}")
        print(f"  height: {height}")
        print(f"  depth: {depth} bits per pixel")
        colors = pic.colors if hasattr(pic, 'colors') else 0
        print(f"  number of colors: {colors} (0 for non-indexed)")
        data_size = len(pic.data) if pic.data else 0
        print(f"  picture data length: {data_size} bytes")

def add_flac_cover(audio: FLAC, img_path: str, file_path: str) -> None:
    if not exists(img_path):
        print(f"error: cover image not found: {img_path} (file: {file_path})", file=sys.stderr)
        sys.exit(1)
    try:
        with open(img_path, 'rb') as f:
            img_data = f.read()
        pic = Picture()
        pic.type = 3  # Front cover (FLAC standard)
        pic.mime = b'image/jpeg' if img_path.lower().endswith(('jpg', 'jpeg')) else b'image/png'
        pic.desc = b''
        pic.data = img_data
        try:
            from PIL import Image
            with Image.open(img_path) as img:
                pic.width, pic.height = img.size
                pic.depth = img.bits if hasattr(img, 'bits') else 24
        except (ImportError, Exception):
            pic.width = 0
            pic.height = 0
            pic.depth = 0
        audio.add_picture(pic)
    except Exception as e:
        print(f"error: add cover failed for {file_path}: {e}", file=sys.stderr)
        sys.exit(1)

# -----------------------------------------------------------------------------
# Main CLI Logic
# -----------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description='Tiny VorbisComment/FLAC CLI tag editor (opustags-style UX, MATCHES apev2tags.py). '
                    'FEATURES: Batch processing (1+ files) | Opt-in sparse punching (-G) | Hardlink-aware deduplication | Stdin/stdout support (- as single file). '
                    'PRE-COMMIT ORDER (fixed): 1)-F → 2)-f → 3)-D → 4)-d → 5)-s → 6)-a → 7)-P → 8)FLAC cover ops. '
                    'FAIL FAST: Aborts on missing/corrupted/non-regular files (arg parsing stage). '
                    'DEDUPLICATION: Only ≥2 files; uses dev/inode triplet; skips duplicates after first successful write. '
                    'STDIN/STDOUT: Use - as single positional param to read from stdin, apply ops, write modified audio to stdout (binary). '
                    'EXIT CODE: 0=all writes success; 1=partial/full failure.',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    # Opt-in sparse hole punching
    parser.add_argument('-G', '--punch-hole', action='store_true', 
                        help='[LINUX ONLY] Opt-in sparse hole punching for zero padding (saves disk space)')
    # Core list/info (mutually exclusive)
    core_list_group = parser.add_mutually_exclusive_group()
    core_list_group.add_argument('-l', '--list', action='store_true', help='Show all tags (exclusive with modify ops)')
    core_list_group.add_argument('--flac-list-picture', action='store_true', help='Show FLAC picture blocks (metaflac-compatible, FLAC only)')
    # Padding (mutually exclusive)
    padding_group = parser.add_mutually_exclusive_group()
    padding_group.add_argument(
        '--padding', type=int, metavar='BYTES',
        help='Set exact padding size (non-negative integer)'
    )
    padding_group.add_argument(
        '--align-padding', type=int, metavar='BLOCKSIZE',
        help='Align file size to multiple of BLOCKSIZE (positive integer)'
    )
    # Import/purge/delete (FIXED: Combined mutual exclusivity for -D/-d; removed useless f_d_mutual_group)
    import_core_group = parser.add_mutually_exclusive_group()
    import_core_group.add_argument('-F', '--from-file', metavar='FILE', help='Clear → import tags (file/stdin "-", exclusive with -f)')
    # FIX 1: Del/Purge mutual group (enforces -D and -d are exclusive)
    del_purge_group = parser.add_mutually_exclusive_group()
    import_core_group.add_argument('-f', '--import-from-file', metavar='FILE', help='Append tags (file/stdin "-", exclusive with -F/-D)')
    del_purge_group.add_argument('-D', '--purge', action='store_true', help='Purge all tags (FLAC: + pictures, exclusive with -d/-f)')
    del_purge_group.add_argument('-d', '--delete', nargs='+', metavar='KEY', help='Delete tags (case-insensitive, exclusive with -D; REQUIRES ≥1 KEY)')
    # Core modify flags (SET/ADD)
    parser.add_argument('-s', '--set', nargs='+', metavar='KEY=VALUE', help='Set/replace tags (last occurrence wins; REQUIRES ≥1 KEY=VALUE)')
    parser.add_argument('-a', '--add', nargs='+', metavar='KEY=VALUE', help='Append multi-value tags (preserve order; REQUIRES ≥1 KEY=VALUE)')
    # FLAC cover ops (mutually exclusive)
    flac_cover_mutex = parser.add_mutually_exclusive_group()
    flac_cover_mutex.add_argument('-P', '--flac-purge-picture', action='store_true', help='[FLAC ONLY] Purge all picture blocks')
    flac_cover_mutex.add_argument('--flac-add-cover', metavar='IMAGE_FILE', help='[FLAC ONLY] Append front cover (jpg/png)')
    flac_cover_mutex.add_argument('-I', '--flac-only-a-cover', metavar='IMAGE_FILE', action='append', help='[FLAC ONLY] Purge pics → add cover (last file wins)')
    # Commit (mutually exclusive)
    commit_group = parser.add_mutually_exclusive_group()
    commit_group.add_argument('-W', '--commit-write-anyway', action='store_true', help='Commit unconditionally (exclusive with -w)')
    commit_group.add_argument('-w', '--commit', action='store_true', help='Commit only if tags/pictures changed')
    # FIX 4: Positional files moved to END (idiomatic CLI)
    parser.add_argument('files', nargs='+', help='Target files (flac/ogg/oga/opus; regular files after symlink resolve) | Use - for stdin/stdout (single param only)')
    
    # Parse args FIRST (required for validation)
    args = parser.parse_args()
    # FIX 2: Enforce list flags are EXCLUSIVE with all modify/padding ops (argparse level check)
    list_flags = [args.list, args.flac_list_picture]
    modify_ops = [
        args.set, args.add, args.delete, args.purge, args.from_file, args.import_from_file,
        args.flac_purge_picture, args.flac_add_cover, args.flac_only_a_cover,
        args.padding, args.align_padding
    ]
    if any(list_flags) and any(m is not None for m in modify_ops):
        parser.error("list flags (-l/--flac-list-picture) cannot be used with modify/padding operations")
    # -------------------------------------------------------------------------
    # NEW: Validate min 1 argument for -s/--set, -a/--add, -d/--delete
    # -------------------------------------------------------------------------
    if args.set is not None and len(args.set) == 0:
        print("error: -s/--set requires at least 1 KEY=VALUE argument", file=sys.stderr)
        sys.exit(1)
    if args.add is not None and len(args.add) == 0:
        print("error: -a/--add requires at least 1 KEY=VALUE argument", file=sys.stderr)
        sys.exit(1)
    if args.delete is not None and len(args.delete) == 0:
        print("error: -d/--delete requires at least 1 KEY argument", file=sys.stderr)
        sys.exit(1)
    # Original validation logic (padding)
    if args.padding is not None and args.padding < 0:
        print(f"error: --padding must be non-negative (got {args.padding})", file=sys.stderr)
        sys.exit(1)
    if args.align_padding is not None and args.align_padding <= 0:
        print(f"error: --align-padding must be positive (got {args.align_padding})", file=sys.stderr)
        sys.exit(1)

    # -------------------------------------------------------------------------
    # NEW: Stdin/stdout handling (single - positional parameter)
    # -------------------------------------------------------------------------
    stdin_mode = False
    stdin_buffer = None
    if len(args.files) == 1 and args.files[0] == '-':
        stdin_mode = True
        print("=== Stdin mode: reading audio data from stdin (binary) ===", file=sys.stderr)
        # Read all stdin data into in-memory BytesIO buffer (read until EOF)
        try:
            stdin_buffer = BytesIO(sys.stdin.buffer.read())
            if stdin_buffer.getbuffer().nbytes == 0:
                print("error: empty stdin input (no audio data)", file=sys.stderr)
                sys.exit(1)
        except Exception as e:
            print(f"error: failed to read stdin: {e}", file=sys.stderr)
            sys.exit(1)
        # Bypass deduplication for stdin mode (no file system triplet)
        unique_resolved_files = ['-']
    else:
        # Step 1: Resolve + validate all files (abort on failure)
        print("Validating input files (symlink resolve + regular file check)...", file=sys.stderr)
        resolved_files = []
        for file_path in args.files:
            resolved_path = resolve_and_check_regular_file(file_path)
            resolved_files.append(resolved_path)
        # Step 2: Conditional deduplication (only ≥2 files)
        unique_resolved_files = resolved_files
        duplicate_count = 0
        if len(resolved_files) >= 2:
            seen_triplets: Set[Tuple[int, int, int]] = set()
            unique_resolved_files = []
            for path in resolved_files:
                triplet = get_file_ident_triplet(path)
                if triplet not in seen_triplets:
                    seen_triplets.add(triplet)
                    unique_resolved_files.append(path)
                else:
                    duplicate_count += 1
                    print(f"warning: duplicate file (same dev/inode) → skipping: {path}", file=sys.stderr)
            
            # Print summary only if duplicates exist
            if duplicate_count > 0:
                print(f"deduplication complete: {len(resolved_files)} → {len(unique_resolved_files)} unique files (skipped {duplicate_count})", file=sys.stderr)

    args.files = unique_resolved_files
    # Initialize state trackers
    write_failures = 0
    written_triplets: Set[Tuple[int, int, int]] = set()  # Track ONLY actually written files
    # Step 3: Batch process unique files
    for file_path in args.files:
        print(f"\n=== Processing: {file_path if not stdin_mode else 'stdin/stdout'} ===", file=sys.stderr)
        # Runtime deduplication: Skip if already written (bypassed for stdin)
        current_triplet = get_file_ident_triplet(file_path)
        if current_triplet in written_triplets and not stdin_mode:
            print(f"warning: file already successfully written → skipping: {file_path}", file=sys.stderr)
            continue
        # Open file (abort on corruption) - use stdin buffer if in stdin mode
        try:
            audio = open_audio_file(file_path, stdin_buffer if stdin_mode else None)
        except MutagenError as e:
            print(f"error: failed to open file (corrupted) → aborting batch: {e}", file=sys.stderr)
            sys.exit(1)
        # Handle FLAC picture list (highest priority)
        if args.flac_list_picture:
            print_flac_pictures(audio, file_path if not stdin_mode else 'stdin')
            continue
        # Initialize empty tags if needed
        if not audio.tags:
            audio.clear()
        # Load original for change detection (abort on failure) - use stdin buffer if in stdin mode
        try:
            original_audio = open_audio_file(file_path, stdin_buffer if stdin_mode else None)
        except MutagenError as e:
            print(f"error: failed to read original tags → aborting batch: {e}", file=sys.stderr)
            sys.exit(1)
        dirty = False
        # Pre-commit operations (fixed order)
        if args.from_file:
            audio.clear()
            for k, v in load_tags(args.from_file):
                audio[k] = [v]
            dirty = True
        if args.import_from_file:
            for k, v in load_tags(args.import_from_file):
                if k in audio:
                    audio[k].append(v)
                else:
                    audio[k] = [v]
            dirty = True
        if args.purge:
            audio.clear()
            if isinstance(audio, FLAC):
                audio.clear_pictures()
            dirty = True
        if args.delete:
            for k in args.delete:
                k_upper = k.strip().upper()
                if k_upper in audio:
                    del audio[k_upper]
                    dirty = True
        if args.set:
            set_dict = {}
            for kv in args.set:
                k, v = parse_kv(kv)
                set_dict[k] = v
            for k, v in set_dict.items():
                audio[k] = [v]
                dirty = True
        if args.add:
            for kv in args.add:
                k, v = parse_kv(kv)
                if k in audio:
                    audio[k].append(v)
                else:
                    audio[k] = [v]
                dirty = True
        # FLAC picture operations
        if isinstance(audio, FLAC):
            if args.flac_purge_picture and len(audio.pictures) > 0:
                audio.clear_pictures()
                dirty = True
            if args.flac_add_cover:
                add_flac_cover(audio, args.flac_add_cover, file_path if not stdin_mode else 'stdin')
                dirty = True
            if args.flac_only_a_cover:
                last_cover = args.flac_only_a_cover[-1]
                if len(audio.pictures) > 0:
                    audio.clear_pictures()
                    dirty = True
                add_flac_cover(audio, last_cover, file_path if not stdin_mode else 'stdin')
                dirty = True
        # Handle tag list (no write)
        trigger_list = [
            args.list,
            not (args.set or args.add or args.delete or args.purge or args.from_file or
                 args.import_from_file or args.flac_add_cover or args.flac_purge_picture or args.flac_only_a_cover or
                 args.padding is not None or args.align_padding is not None)
        ]
        if any(trigger_list):
            if not audio:
                print("(no tags)")
            else:
                for k in sorted(audio.keys()):
                    for val in audio[k]:
                        print(f"{k}={val}")
            continue
        # Handle padding preview (no write) - skip for stdin mode (no file size preview)
        padding_specified = args.padding is not None or args.align_padding is not None
        no_commit = not args.commit_write_anyway and not args.commit
        if padding_specified and no_commit and not stdin_mode:
            try:
                buf = BytesIO()
                audio.save(buf, padding=0)
                base_size = len(buf.getvalue())
                final_padding = 0
                if args.padding is not None:
                    final_padding = args.padding
                elif args.align_padding is not None:
                    remainder = base_size % args.align_padding
                    final_padding = args.align_padding - remainder if remainder != 0 else 0
                print(f"[preview] base_size: {base_size}B | padding: {final_padding}B | final_size: {base_size+final_padding}B", file=sys.stderr)
            except Exception as e:
                print(f"[preview-error] precompute failed → skipping: {e}", file=sys.stderr)
            continue
        # Commit changes (track only successful writes)
        if (args.commit_write_anyway or args.commit) and dirty:
            try:
                # Skip if no changes (--commit flag)
                if args.commit and tags_are_equal(audio, original_audio):
                    print("no changes detected → skipping commit", file=sys.stderr)
                    continue
                # Calculate padding
                final_padding = None
                if args.padding is not None:
                    final_padding = args.padding
                elif args.align_padding is not None:
                    buf = BytesIO()
                    audio.save(buf, padding=0)
                    base_size = len(buf.getvalue())
                    remainder = base_size % args.align_padding
                    final_padding = args.align_padding - remainder if remainder != 0 else 0

                # -----------------------------------------------------------------
                # NEW: Stdout write for stdin mode (binary)
                # -----------------------------------------------------------------
                if stdin_mode:
                    print("=== Writing modified audio data to stdout (binary) ===", file=sys.stderr)
                    # Save modified audio to BytesIO buffer, then write to stdout binary
                    output_buffer = BytesIO()
                    audio.save(output_buffer, padding=final_padding)
                    output_buffer.seek(0)
                    # Write all binary data to stdout (bypass text mode)
                    sys.stdout.buffer.write(output_buffer.read())
                    sys.stdout.buffer.flush()
                    print("=== Stdout write complete ===", file=sys.stderr)
                else:
                    # Original file write logic (with sparse punching if enabled)
                    if args.punch_hole:
                        with SparseTagFile(file_path) as f:
                            audio.save(f, padding=final_padding)
                        sparse_note = " (sparse holes punched)"
                    else:
                        audio.save(padding=final_padding)
                        sparse_note = ""
                    # Success message + track triplet (ONLY after successful write)
                    padding_note = f" (padding: {final_padding}B)" if final_padding is not None else ""
                    print(f"tags committed{padding_note}{sparse_note}", file=sys.stderr)
                    written_triplets.add(current_triplet)

            except MutagenError as e:
                print(f"error: mutagen commit failed → skipping: {e}", file=sys.stderr)
                write_failures += 1
            except Exception as e:
                print(f"error: file save failed → skipping: {e}", file=sys.stderr)
                write_failures += 1

    # Final summary
    total_unique = len(args.files)
    successful = total_unique - write_failures
    print(f"\n=== Batch Complete ===", file=sys.stderr)
    print(f"Total unique files: {total_unique} | Successful: {successful} | Failed writes: {write_failures}", file=sys.stderr)
    # Exit code (0=success, 1=failure)
    sys.exit(1 if write_failures > 0 else 0)

if __name__ == '__main__':
    main()
