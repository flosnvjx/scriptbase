#!/usr/bin/env shorthandzsh

declare +x key=$$.$RANDOM
declare +x rate=${${(M)argv[1]:#<44100->}:-44100}
declare +x gain=0 gaine=
! test -t 0
! test -t 1
MemDAV -listen-http 127.0.0.2:45555 -username a -password a >/dev/null &
trap ZERR 'local abr=$?; pkill -INT MemDAV >/dev/null; exit $abr'
trap EXIT 'local abr=$?; pkill -INT MemDAV >/dev/null; exit $abr'
sleep 0.2 >/dev/null
curl -fsT - -u a:a 'http://127.0.0.2:45555/'$key >/dev/null

ffmpeg -loglevel warning -xerror -err_detect explode -i http://a:a@127.0.0.2:45555/$key -f null /dev/null

declare -A ffprobe
ffprobe=( "${(@Q)${(@z)${(@f)$(exec ffprobe -loglevel warning -of flat -show_streams http://a:a@127.0.0.2:45555/$key)}/=/ }}" )

if (( ffprobe[streams.stream.0.sample_rate] % rate )) || [[ "${ffprobe[streams.stream.0.sample_fmt]}" != (s16|s16p) ]]; then
  until ! ffmpeg -loglevel warning -xerror -err_detect explode -i http://a:a@127.0.0.2:45555/$key -f wav - | sox -V3 -Dtwav --ignore-length - ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+-b16} ${${ffprobe[streams.stream.0.sample_rate]:#$rate}:+-r$rate} -n ${(z)${gain:#0}:+vol -${gaine}dB} ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+dither} 2>&1 | grep -q clipped; do
    gain=$((gain+0.1))
    printf -v gaine '%.1f' $((gain))
  done
  ffmpeg -loglevel warning -xerror -err_detect explode -i http://a:a@127.0.0.2:45555/$key -f wav - | sox -Dtwav --ignore-length - ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+-b16} ${${ffprobe[streams.stream.0.sample_rate]:#$rate}:+-r$rate} -twav - ${(z)${gain:#0}:+vol -${gaine}dB} ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+dither}
else
  ffmpeg -loglevel warning -xerror -err_detect explode -i http://a:a@127.0.0.2:45555/$key -f wav -
fi
