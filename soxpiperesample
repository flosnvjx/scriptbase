#!/usr/bin/env shorthandzsh

function main {
declare +x key=$$.$RANDOM
declare +x rate=${${(M)argv[1]:#<44100->}:-44100}
declare +x gain=0 gaine=
! test -t 0
! test -t 1
declare +x port=$$
printf -v port '%04d' ${port[1,4]}
port=4$port
if [[ -v commands[MemDAV] ]]; then
MemDAV -listen-http 127.0.0.2:$port -username a -password a >/dev/null &
trap 'local abr=$?; pkill MemDAV >/dev/null; exit $abr' ZERR TERM INT
sleep 0.2 >/dev/null
curl -fsT - -u a:a http://127.0.0.2:$port/$key >/dev/null
declare +x mktemp=
else
declare +x mktemp="$(exec mktemp)"
tee -- $mktemp >&-
fi

ffmpeg -loglevel warning -xerror -err_detect explode -i ${mktemp:-http://a:a@127.0.0.2:$port/$key} -f null /dev/null

declare -A ffprobe
ffprobe=( "${(@Q)${(@z)${(@f)$(exec ffprobe -loglevel warning -of flat -show_streams ${mktemp:-http://a:a@127.0.0.2:$port/$key})}/=/ }}" )


## TODO detect upsampled input
#if [[ "${ffprobe[streams.stream.0.sample_rate]}" != (s16|s16p) ]]; then
#  declare statsBitDepth=
#else
#  declare statsBitDepth=
#fi

until ffmpeg -loglevel warning -xerror -err_detect explode -i ${mktemp:-http://a:a@127.0.0.2:$port/$key} -f wav - | sox -Dtwav --ignore-length - ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+-b16} -n ${(z)${gain:#0}:+vol -${gaine}dB} ${(z)${ffprobe[streams.stream.0.sample_rate]:#$rate}:+rate $rate} ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+dither} rate -m ${${${(M)rate:#44100}:+48000}:-44100} 2>&1 | awk '/clipped/{ng=1}END{if (ng) {exit(1)}}'; do
  gain=$((gain+0.1))
  printf -v gaine '%.1f' $((gain))
done
ffmpeg -loglevel warning -xerror -err_detect explode -i ${mktemp:-http://a:a@127.0.0.2:$port/$key} -f wav - | sox -Dtwav --ignore-length - ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+-b16} -twav - ${(z)${gain:#0}:+vol -${gaine}dB} ${(z)${ffprobe[streams.stream.0.sample_rate]:#$rate}:+rate $rate} ${${ffprobe[streams.stream.0.sample_fmt]:#s16(|p)}:+dither}
}

main "${(@)argv}"
if [[ -v commands[MemDAV] ]]; then
pkill MemDAV >/dev/null
else
rm -- $mktemp
fi
